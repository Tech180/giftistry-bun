{
  "name": "giftistry-api",
  "version": "0.0.9",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "cd ../theming-engine && bun run build",
    "dev": "bun --hot src/index.ts",
    "prestart": "cd ../theming-engine && bun run build",
    "start": "NODE_ENV=production bun src/index.ts",
    "pretest": "bun run scripts/ensure-test-database.ts",
    "test": "bun test",
    "reset-database": "bun run scripts/reset-database.ts",
    "dev:all": "concurrently \"bun run dev\" \"cd ../giftistry-react && npm start\""
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/swagger": "^1.3.1",
    "@simplewebauthn/server": "^13.3.2",
    "elysia": "^1.4.28",
    "nodemailer": "^9.0.1",
    "otplib": "^13.4.1",
    "postgres": "^3.4.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/nodemailer": "^8.0.1",
    "concurrently": "^9.2.1"
  }
}
