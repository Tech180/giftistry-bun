# Giftistry backend environment (non-secrets and bootstrap flags)
# Copy to .env and adjust for your homelab. Secrets can also use *_FILE or CREDENTIALS_DIRECTORY.

NODE_ENV=development
PORT=3001

# PostgreSQL (local defaults work with Nix/dev shell)
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=postgres
PGDATABASE=giftistry
# PGPASSWORD or PGPASSWORD_FILE or $CREDENTIALS_DIRECTORY/PGPASSWORD

# JWT — required in production (min 32 chars, not a default)
# JWT_SECRET or JWT_SECRET_FILE or $CREDENTIALS_DIRECTORY/JWT_SECRET

# Public URL served to browsers (emails, CORS, WebAuthn). Also configurable in config.json as PublicAppUrl.
GIFTISTRY_PUBLIC_APP_URL=http://localhost:3000

# First-run setup controls
GIFTISTRY_ALLOW_SETUP=true
# GIFTISTRY_SETUP_TOKEN or GIFTISTRY_SETUP_TOKEN_FILE — when set, POST /api/system/setup requires header or body token

# Optional path override for config.json
# GIFTISTRY_CONFIG_PATH=/var/lib/giftistry/config.json

# SMTP defaults (overridden by config.json when SmtpType=remote)
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USER=
# SMTP_PASS or SMTP_PASS_FILE
SMTP_SECURE=false
SMTP_FROM=noreply@giftistry.local

# AI provider fallbacks when slot keys are empty in config.json
# OPENROUTER_API_KEY or OPENROUTER_API_KEY_FILE
# GEMINI_API_KEY or GEMINI_API_KEY_FILE

# OAuth client secret (issuer/client id live in config.json)
# OAUTH_CLIENT_SECRET or OAUTH_CLIENT_SECRET_FILE

# Credentials directory (alternative to individual *_FILE vars)
# CREDENTIALS_DIRECTORY=/run/secrets/giftistry
# GIFTISTRY_CREDENTIALS_DIRECTORY=/run/secrets/giftistry
