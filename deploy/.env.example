# Copy to .env and fill in values before `docker compose up`.

# --- Web ---
WEB_PORT=8080

# --- PostgreSQL ---
PGUSER=giftistry
PGPASSWORD=change-me-use-a-long-random-password
PGDATABASE=giftistry

# --- API secrets (use ONE of JWT_SECRET, JWT_SECRET_FILE, or CREDENTIALS_DIRECTORY) ---
# Must be at least 32 characters in production.
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
# JWT_SECRET_FILE=/run/secrets/jwt_secret
# CREDENTIALS_DIRECTORY=/run/secrets

# --- Public URL (emails, passkeys, OAuth redirects) ---
GIFTISTRY_PUBLIC_APP_URL=http://localhost:8080

# --- First-run setup ---
GIFTISTRY_ALLOW_SETUP=true
# GIFTISTRY_SETUP_TOKEN=

# --- SMTP (defaults target Mailpit when profile `mail` is enabled) ---
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_FROM=noreply@giftistry.local

# --- Optional Mailpit host ports (profile: mail) ---
MAILPIT_UI_PORT=8025
MAILPIT_SMTP_PORT=1025
